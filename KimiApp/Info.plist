<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App identity -->
    <key>CFBundleName</key>
    <string>KimiApp</string>
    <key>CFBundleDisplayName</key>
    <string>KimiApp</string>
    <key>CFBundleIdentifier</key>
    <string>com.iahiax.kimiapp</string>

    <!-- Versioning -->
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>

    <!-- Launch storyboard -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

    <!-- App Transport Security (example allows arbitrary loads; change for production) -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>

    <!-- Scene Manifest -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
        <key>UISceneConfigurations</key>
        <dict>
            <key>UIWindowSceneSessionRoleApplication</key>
            <array>
                <dict>
                    <key>UISceneConfigurationName</key>
                    <string>Default Configuration</string>
                    <key>UISceneDelegateClassName</key>
                    <string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
                    <!-- Optionally: storyboard name if you use a storyboard for the scene -->
                    <!-- <key>UISceneStoryboardFile</key><string>Main</string> -->
                </dict>
            </array>
        </dict>
    </dict>

    <!-- Supported interface orientations -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>

    <!-- Privacy usage descriptions (fill appropriately for App Store) -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>This app requires access to your photo library.</string>
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>This app requires permission to save images.</string>
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>Location access is required for enhanced functionality.</string>
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>Location access is required for enhanced functionality.</string>
    <key>NSLocationAlwaysUsageDescription</key>
    <string>Location access is required for enhanced functionality.</string>
    <key>NSContactsUsageDescription</key>
    <string>Contacts access is required for enhanced functionality.</string>
    <key>NSCalendarsUsageDescription</key>
    <string>Calendar access is required for enhanced functionality.</string>
    <key>NSCameraUsageDescription</key>
    <string>Camera access is required for enhanced functionality.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Microphone access is required for enhanced functionality.</string>
</dict>
</plist>
